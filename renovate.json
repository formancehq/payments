{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>formancehq/shared-config//renovate/presets/golang"
  ],
  "ignoreDeps": [
    "github.com/formancehq/payments/pkg/client"
  ],
  "ignorePaths": [
      "**/pkg/client/**",
      "internal/connectors/plugins/public/generic/client/generated/"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["github.com/formancehq/payments/pkg/domain"],
      "matchFileNames": ["ce/plugins/**/go.mod"],
      "groupName": "pkg/domain for ce/plugins",
      "groupSlug": "ce-plugins-pkg-domain"
    }
  ]
}
